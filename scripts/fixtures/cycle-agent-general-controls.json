{
  "commands": [
    {
      "command": "inspectTargets",
      "area": "AreaGenControls"
    },
    {
      "command": "inspectTree",
      "area": "AreaGenControls",
      "maxDepth": 3,
      "maxNodes": 120
    },
    {
      "command": "action",
      "actionType": "SwitchToTool",
      "id": "IdToolPencil"
    },
    {
      "command": "inspectTargets",
      "area": "AreaGenControls"
    },
    {
      "command": "assertTarget",
      "area": "AreaGenControls",
      "path": "automationState.tools.name",
      "equals": "pencil"
    },
    {
      "command": "pointer",
      "area": "AreaGenControls",
      "target": "TargSelector",
      "event": "click",
      "waitForIdle": true,
      "idleDelayMs": 50
    },
    {
      "command": "assertTarget",
      "area": "AreaGenControls",
      "path": "automationState.tools.name",
      "equals": "selector"
    }
  ],
  "quit": true
}
