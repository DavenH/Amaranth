{
  "commands": [
    {
      "command": "openFactoryPreset",
      "preset": "african-horn",
      "waitForIdle": true,
      "idleDelayMs": 300
    },
    {
      "command": "captureAudio",
      "path": "/private/tmp/cycle-agent-africanhorn-c4.wav",
      "durationMs": 1500,
      "sampleRate": 44100,
      "blockSize": 512,
      "channels": 2,
      "events": [
        {
          "type": "noteOn",
          "timeMs": 0,
          "note": 60,
          "velocity": 0.8,
          "channel": 1
        },
        {
          "type": "noteOff",
          "timeMs": 850,
          "note": 60,
          "channel": 1
        }
      ],
      "peakGreaterThan": 0.0001,
      "rmsGreaterThan": 0.00001,
      "peakLessThan": 1.5
    }
  ],
  "quit": true
}
