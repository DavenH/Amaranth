* text=auto

# Source and project text files use LF in the repository and worktree.
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.h text eol=lf
*.hh text eol=lf
*.hpp text eol=lf
*.m text eol=lf
*.mm text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.plist text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Presets and media assets are binary.
*.cyc binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.icns binary
*.wav binary
*.aif binary
*.aiff binary
*.mp3 binary
